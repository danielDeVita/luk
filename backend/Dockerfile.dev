FROM node:22-alpine

WORKDIR /app

# Install dependencies for native modules + curl for healthcheck
RUN apk add --no-cache python3 make g++ curl

# Copy package files
COPY package*.json ./
RUN npm install

# Copy prisma schema for generation
COPY prisma ./prisma/
RUN npx prisma generate

# Source code mounted via volume
EXPOSE 3001 5555

CMD ["npm", "run", "start:dev"]
