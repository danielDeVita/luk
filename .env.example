# ============================================
# RAFFLE PLATFORM - ENVIRONMENT VARIABLES
# ============================================
# Single file for all services (backend, frontend, docker)

# ============================================
# DATABASE
# ============================================
DATABASE_URL="postgresql://raffle_user:raffle_password@localhost:5432/raffle_db"

# ============================================
# APPLICATION
# ============================================
NODE_ENV="development"
PORT="3001"
FRONTEND_URL="http://localhost:3000"
BACKEND_URL="http://localhost:3001"

# ============================================
# AUTHENTICATION
# ============================================
JWT_SECRET="your-super-secret-jwt-key-change-in-production-min-32-chars"

# ============================================
# GOOGLE OAUTH
# ============================================
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"
GOOGLE_CALLBACK_URL="http://localhost:3001/auth/google/callback"

# ============================================
# MERCADO PAGO
# ============================================
MP_ACCESS_TOKEN="TEST-your-access-token"
MP_PLATFORM_FEE_PERCENT="4"
# Set to "true" to bypass real MP refund/release calls in local QA
MP_MOCK_MODE="false"

# ============================================
# CLOUDINARY
# ============================================
CLOUDINARY_CLOUD_NAME="your-cloud-name"
CLOUDINARY_API_KEY="your-api-key"
CLOUDINARY_API_SECRET="your-api-secret"

# ============================================
# EMAIL (BREVO - formerly Sendinblue)
# ============================================
# Get API key from https://app.brevo.com/settings/keys/api
# Free tier: 300 emails/day, no domain required
BREVO_API_KEY="xkeysib-your-api-key-here"
EMAIL_FROM="noreply@tudominio.com"
EMAIL_FROM_NAME="Plataforma de Rifas"

# ============================================
# RATE LIMITING
# ============================================
THROTTLE_TTL="60"
THROTTLE_LIMIT="100"

# ============================================
# LOGGING
# ============================================
LOG_LEVEL="debug"

# ============================================
# CRON JOBS
# ============================================
ENABLE_CRON_JOBS="true"

# ============================================
# CORS & GRAPHQL
# ============================================
CORS_ORIGIN="http://localhost:3000"
GRAPHQL_PLAYGROUND="true"
GRAPHQL_DEBUG="true"

# ============================================
# FRONTEND PUBLIC VARIABLES
# ============================================
# These are exposed to the browser (safe to be public)
NEXT_PUBLIC_GRAPHQL_URL="http://localhost:3001/graphql"
NEXT_PUBLIC_GRAPHQL_WS_URL="ws://localhost:3001/graphql"
NEXT_PUBLIC_BACKEND_URL="http://localhost:3001"

# ============================================
# MP CONNECT OAUTH (Seller Onboarding)
# ============================================
# Get from https://www.mercadopago.com.ar/developers/panel/app
MP_CLIENT_ID=""
MP_CLIENT_SECRET=""
# Optional: Separate webhook secret (falls back to MP_CLIENT_SECRET if not set)
MP_WEBHOOK_SECRET=""

# ============================================
# ENCRYPTION (PII Protection)
# ============================================
# 64-character hex key for AES-256-GCM encryption of sensitive data
# Generate with: openssl rand -hex 32
ENCRYPTION_KEY="some-64-character-hex-string-here"

# ============================================
# GOOGLE ANALYTICS - OPTIONAL
# ============================================
# Get Measurement ID from https://analytics.google.com
# Format: G-XXXXXXXXXX
NEXT_PUBLIC_GA_MEASUREMENT_ID=""

# ============================================
# SENTRY (Error Tracking) - OPTIONAL
# ============================================
# Get DSN from https://sentry.io - leave empty to disable
# Backend
SENTRY_DSN=""
# Frontend (exposed to browser)
NEXT_PUBLIC_SENTRY_DSN=""
SENTRY_ORG=""
SENTRY_PROJECT=""
