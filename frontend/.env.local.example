# ============================================
# LUK FRONTEND - ENVIRONMENT VARIABLES
# ============================================
# Local Next.js config. NEXT_PUBLIC_* values are exposed to the browser.
# Keep frontend/.env.local free of backend-only secrets.

# ============================================
# PUBLIC URLS
# ============================================
NEXT_PUBLIC_GRAPHQL_URL="http://localhost:3001/graphql"
NEXT_PUBLIC_GRAPHQL_WS_URL="ws://localhost:3001/graphql"
NEXT_PUBLIC_BACKEND_URL="http://localhost:3001"
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# ============================================
# TURNSTILE (Browser public key)
# ============================================
NEXT_PUBLIC_TURNSTILE_ENABLED="false"
NEXT_PUBLIC_TURNSTILE_SITE_KEY=""

# ============================================
# GOOGLE ANALYTICS - OPTIONAL
# ============================================
NEXT_PUBLIC_GA_MEASUREMENT_ID=""

# ============================================
# SENTRY (Frontend/browser + Next server build)
# ============================================
NEXT_PUBLIC_SENTRY_DSN=""
NEXT_PUBLIC_SENTRY_RELEASE=""
SENTRY_DSN=""
SENTRY_RELEASE=""
SENTRY_ORG=""
SENTRY_PROJECT=""
