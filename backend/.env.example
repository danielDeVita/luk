# ============================================
# LUK BACKEND - ENVIRONMENT VARIABLES
# ============================================
# Local backend, social worker, and Prisma config.
# Keep secrets in backend/.env; that file is ignored by git.

# ============================================
# DATABASE (Local PostgreSQL + Redis)
# ============================================
# Default local Docker mapping uses 5433 to avoid conflicts with native PostgreSQL on 5432.
DATABASE_URL="postgresql://raffle_user:raffle_password@localhost:5433/raffle_db"
REDIS_URL="redis://localhost:6379"

# ============================================
# APPLICATION
# ============================================
NODE_ENV="development"
PORT="3001"
FRONTEND_URL="http://localhost:3000"
BACKEND_URL="http://localhost:3001"

# ============================================
# AUTHENTICATION
# ============================================
JWT_SECRET="your-super-secret-jwt-key-change-in-production-min-32-chars"

# ============================================
# GOOGLE OAUTH
# ============================================
# For local dev: http://localhost:3001/auth/google/callback
# For production: set this to the public backend callback URL in the deploy provider.
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"
GOOGLE_CALLBACK_URL="http://localhost:3001/auth/google/callback"

# ============================================
# MERCADO PAGO
# ============================================
MP_ACCESS_TOKEN=""
PLATFORM_FEE_PERCENT="4"
# Use "mercado_pago" in production, "mock" for local QA without MP.
PAYMENTS_PROVIDER="mock"
# In production this must stay false unless you explicitly want the mock UI enabled.
ALLOW_MOCK_PAYMENTS="true"

# ============================================
# CLOUDINARY
# ============================================
CLOUDINARY_CLOUD_NAME="your-cloud-name"
CLOUDINARY_API_KEY="your-api-key"
CLOUDINARY_API_SECRET="your-api-secret"

# ============================================
# EMAIL (BREVO - formerly Sendinblue)
# ============================================
# Get API key from https://app.brevo.com/settings/keys/api
BREVO_API_KEY="xkeysib-your-api-key-here"
EMAIL_FROM="noreply@tudominio.com"
EMAIL_FROM_NAME="LUK"

# ============================================
# RATE LIMITING
# ============================================
THROTTLE_TTL="60"
THROTTLE_LIMIT="100"

# ============================================
# LOGGING
# ============================================
LOG_LEVEL="debug"

# ============================================
# CRON JOBS
# ============================================
ENABLE_CRON_JOBS="true"

# ============================================
# SOCIAL PROMOTIONS
# ============================================
SOCIAL_PROMOTION_ENABLED="true"
SOCIAL_PROMOTION_ALLOWED_NETWORKS="facebook,instagram,x"
SOCIAL_PROMOTION_CHECK_CRON="0 */6 * * *"
SOCIAL_PROMOTION_FETCH_TIMEOUT_MS="30000"
SOCIAL_PROMOTION_MIN_PROVIDER_CHARGE="1"
SOCIAL_PROMOTION_TOKEN_TTL_HOURS="24"
SOCIAL_PROMOTION_DEFAULT_BONUS_TIER_JSON=""
SOCIAL_PROMOTION_BROWSER_ENABLED="false"

# ============================================
# CORS & GRAPHQL
# ============================================
CORS_ORIGIN="http://localhost:3000"
GRAPHQL_PLAYGROUND="true"
GRAPHQL_DEBUG="true"

# ============================================
# AUTH CAPTCHA (Backend only)
# ============================================
TURNSTILE_ENABLED="false"
TURNSTILE_SECRET_KEY=""

# ============================================
# MP CONNECT OAUTH (Seller Onboarding)
# ============================================
MP_CLIENT_ID=""
MP_CLIENT_SECRET=""
MP_WEBHOOK_SECRET=""

# ============================================
# ENCRYPTION (PII Protection)
# ============================================
# 64-character hex key for AES-256-GCM encryption of sensitive data.
# Generate with: openssl rand -hex 32
ENCRYPTION_KEY="some-long-string"

# ============================================
# PRICING
# ============================================
SELECTED_NUMBER_PREMIUM_PERCENT="5"

# ============================================
# SENTRY (Backend + worker)
# ============================================
SENTRY_DSN=""
SENTRY_RELEASE=""
