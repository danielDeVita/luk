# ============================================
# LUK - ENVIRONMENT VARIABLES
# ============================================
# Single file for all services (backend, frontend, docker)

# ============================================
# DATABASE
# ============================================
# Default local Docker mapping uses 5433 to avoid conflicts with native PostgreSQL on 5432
DATABASE_URL="postgresql://raffle_user:raffle_password@localhost:5433/raffle_db"
REDIS_URL="redis://localhost:6379"

# ============================================
# APPLICATION
# ============================================
NODE_ENV="development"
PORT="3001"
FRONTEND_URL="http://localhost:3000"
BACKEND_URL="http://localhost:3001"

# ============================================
# AUTHENTICATION
# ============================================
JWT_SECRET="your-super-secret-jwt-key-change-in-production-min-32-chars"

# ============================================
# GOOGLE OAUTH
# ============================================
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"
GOOGLE_CALLBACK_URL="http://localhost:3001/auth/google/callback"

# ============================================
# MERCADO PAGO
# ============================================
MP_ACCESS_TOKEN=""
PLATFORM_FEE_PERCENT="4"
# Use "mercadopago" in production, "mock" for local QA without MP
PAYMENTS_PROVIDER="mock"
# In production this must stay false unless you explicitly want the mock UI enabled
ALLOW_MOCK_PAYMENTS="true"
# Set to "true" to bypass real MP refund/release calls in local QA
# Legacy alias: if true, forces PAYMENTS_PROVIDER=mock
MP_MOCK_MODE="false || true"

# ============================================
# CLOUDINARY
# ============================================
CLOUDINARY_CLOUD_NAME="your-cloud-name"
CLOUDINARY_API_KEY="your-api-key"
CLOUDINARY_API_SECRET="your-api-secret"

# ============================================
# EMAIL (BREVO - formerly Sendinblue)
# ============================================
# Get API key from https://app.brevo.com/settings/keys/api
# Free tier: 300 emails/day, no domain required
BREVO_API_KEY="xkeysib-your-api-key-here"
EMAIL_FROM="noreply@tudominio.com"
EMAIL_FROM_NAME="LUK"

# ============================================
# RATE LIMITING
# ============================================
THROTTLE_TTL="60"
THROTTLE_LIMIT="100"

# ============================================
# LOGGING
# ============================================
LOG_LEVEL="debug"

# ============================================
# CRON JOBS
# ============================================
ENABLE_CRON_JOBS="true"

# ============================================
# SOCIAL PROMOTIONS
# ============================================
SOCIAL_PROMOTION_ENABLED="true"
SOCIAL_PROMOTION_ALLOWED_NETWORKS="facebook,instagram,x,threads"
SOCIAL_PROMOTION_SUBMISSION_WINDOW_HOURS="24"
SOCIAL_PROMOTION_CHECK_CRON="0 */6 * * *"
SOCIAL_PROMOTION_FETCH_TIMEOUT_MS="30000"
SOCIAL_PROMOTION_MIN_MP_CHARGE="1"
SOCIAL_PROMOTION_TOKEN_TTL_HOURS="24"
SOCIAL_PROMOTION_DEFAULT_BONUS_TIER_JSON=""
SOCIAL_PROMOTION_MAX_USER_MONTHLY_SUBSIDY="0"
SOCIAL_PROMOTION_BROWSER_ENABLED="false"

# ============================================
# CORS & GRAPHQL
# ============================================
CORS_ORIGIN="http://localhost:3000"
GRAPHQL_PLAYGROUND="true"
GRAPHQL_DEBUG="true"

# ============================================
# FRONTEND PUBLIC VARIABLES
# ============================================
# These are exposed to the browser (safe to be public)
NEXT_PUBLIC_GRAPHQL_URL="http://localhost:3001/graphql"
NEXT_PUBLIC_GRAPHQL_WS_URL="ws://localhost:3001/graphql"
NEXT_PUBLIC_BACKEND_URL="http://localhost:3001"

# ============================================
# MP CONNECT OAUTH (Seller Onboarding)
# ============================================
# Get from https://www.mercadopago.com.ar/developers/panel/app
MP_CLIENT_ID=""
MP_CLIENT_SECRET=""
# Optional: Separate webhook secret (falls back to MP_CLIENT_SECRET if not set)
MP_WEBHOOK_SECRET=""

# ============================================
# ENCRYPTION (PII Protection)
# ============================================
# 64-character hex key for AES-256-GCM encryption of sensitive data
# Generate with: openssl rand -hex 32
ENCRYPTION_KEY="some-64-character-hex-string-here"

# ============================================
# GOOGLE ANALYTICS - OPTIONAL
# ============================================
# Get Measurement ID from https://analytics.google.com
# Format: G-XXXXXXXXXX
NEXT_PUBLIC_GA_MEASUREMENT_ID=""

SELECTED_NUMBER_PREMIUM_PERCENT=5

# ============================================
# SENTRY (Error Tracking) - OPTIONAL
# ============================================
# Backend + worker project
SENTRY_DSN=""
SENTRY_RELEASE=""
# Frontend project (browser)
NEXT_PUBLIC_SENTRY_DSN=""
NEXT_PUBLIC_SENTRY_RELEASE=""

# Optional later if you enable source map upload
SENTRY_ORG=""
SENTRY_PROJECT=""
SENTRY_AUTH_TOKEN=""
