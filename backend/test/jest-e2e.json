{
  "moduleFileExtensions": ["js", "json", "ts"],
  "rootDir": ".",
  "testEnvironment": "node",
  "testRegex": ".(e2e-spec|integration.spec).ts$",
  "transform": {
    "^.+\\.(t|j)s$": "ts-jest"
  },
  "testTimeout": 60000,
  "moduleNameMapper": {
    "^otplib$": "<rootDir>/mocks/otplib.ts",
    "^@/(.*)$": "<rootDir>/../src/$1"
  }
}
