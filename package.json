{
  "name": "raffle-platform",
  "version": "1.0.0",
  "private": true,
  "description": "Raffle marketplace platform for Argentina",
  "scripts": {
    "prepare": "husky",
    "lint": "npm run lint:backend && npm run lint:frontend",
    "lint:backend": "cd backend && npm run lint",
    "lint:frontend": "cd frontend && npm run lint",
    "typecheck": "npm run typecheck:backend && npm run typecheck:frontend",
    "typecheck:backend": "cd backend && npx tsc --noEmit",
    "typecheck:frontend": "cd frontend && npx tsc --noEmit",
    "test": "cd backend && npm run test",
    "build": "npm run build:backend && npm run build:frontend",
    "build:backend": "cd backend && npm run build",
    "build:frontend": "cd frontend && npm run build",
    "k6:smoke": "k6 run load-tests/smoke.js",
    "k6:load": "k6 run load-tests/load.js",
    "k6:stress": "k6 run load-tests/stress.js",
    "k6:health": "k6 run load-tests/scenarios/01-health.js",
    "k6:browse": "k6 run load-tests/scenarios/02-browse-homepage.js",
    "k6:search": "k6 run load-tests/scenarios/03-search-filters.js",
    "k6:detail": "k6 run load-tests/scenarios/04-raffle-detail.js",
    "k6:auth": "k6 run load-tests/scenarios/05-auth-flow.js",
    "k6:buy": "k6 run load-tests/scenarios/06-buy-tickets.js",
    "docker:dev": "docker compose -f docker-compose.dev.yml up",
    "docker:dev:build": "docker compose -f docker-compose.dev.yml up --build",
    "docker:dev:down": "docker compose -f docker-compose.dev.yml down",
    "docker:prod": "docker compose up",
    "docker:prod:build": "docker compose up --build",
    "docker:prod:down": "docker compose down",
    "docker:logs": "docker compose -f docker-compose.dev.yml logs -f",
    "docker:logs:backend": "docker compose -f docker-compose.dev.yml logs -f backend",
    "docker:logs:frontend": "docker compose -f docker-compose.dev.yml logs -f frontend",
    "docker:shell:backend": "docker compose -f docker-compose.dev.yml exec backend sh",
    "docker:shell:frontend": "docker compose -f docker-compose.dev.yml exec frontend sh",
    "docker:db:studio": "docker compose -f docker-compose.dev.yml exec backend npx prisma studio",
    "docker:db:push": "docker compose -f docker-compose.dev.yml exec backend npx prisma db push",
    "docker:db:seed": "docker compose -f docker-compose.dev.yml exec backend npm run seed",
    "docker:clean": "docker compose -f docker-compose.dev.yml down -v --rmi local"
  },
  "devDependencies": {
    "husky": "^9.1.7",
    "lint-staged": "^15.4.3",
    "tailwindcss": "^4.1.18"
  },
  "lint-staged": {
    "backend/src/**/*.ts": [
      "eslint --fix"
    ],
    "frontend/src/**/*.{ts,tsx}": [
      "eslint --fix"
    ]
  },
  "dependencies": {
    "@sentry/nextjs": "^10.32.1",
    "tw-animate-css": "^1.4.0"
  }
}
